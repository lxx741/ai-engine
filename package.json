{
  "name": "ai-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise AI Application Engine - Like Coze/Dify",
  "scripts": {
    "dev": "pnpm dev:server & pnpm dev:web",
    "dev:server": "pnpm --filter @ai-engine/server dev",
    "dev:web": "pnpm --filter @ai-engine/web dev",
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "pnpm --filter @ai-engine/server build",
    "build:web": "pnpm --filter @ai-engine/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ai-engine/server db:generate",
    "db:migrate": "pnpm --filter @ai-engine/server db:migrate",
    "db:seed": "pnpm --filter @ai-engine/server db:seed"
  },
  "keywords": [
    "ai",
    "llm",
    "workflow",
    "agent",
    "nestjs",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
